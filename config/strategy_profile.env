# Git-tracked paper strategy profile.
# No secrets here: use this file for safe strategy/risk tweaks that should
# propagate to the server through nightly GitHub auto-updates.

# Keep the spread filter moderate so the paper contour keeps collecting
# enough live MOEX flow for nightly optimization.
SCALPER_MAX_SPREAD_BPS=4.0

# Relax the two dominant daytime blockers a step, otherwise the paper bot
# starves itself of fresh trades and cannot learn from the live session.
SCALPER_MIN_IMBALANCE=0.45
SCALPER_MIN_IMPULSE_BPS=0.5
SCALPER_MIN_EXPECTED_EDGE_BPS=4
SCALPER_TIME_STOP_SECONDS=20

# Expand the liquid watchlist so the paper contour gathers a broader stream
# of candidate setups without leaving the large-cap MOEX core.
SCALPER_WATCHLIST=SBER,GAZP,LKOH,VTBR,YDEX,T,TATN,NVTK

# Paper mode is allowed to explore both long and short directions.
SCALPER_ALLOW_SHORT=1

# Keep the minute regime filter and intraday ticker guard under Git control.
# Do not stop the whole day-session after a few guarded tickers: keep gathering
# live paper statistics across the remaining watchlist and review outcomes at night.
# During paper development keep the session collecting trades even after the
# daily loss threshold so the nightly analyzers retain a real market sample.
# Paper-only ticker guards should cool down and then re-arm, instead of muting
# the same high-liquidity ticker for the rest of the session.
# Nightly auto-tuning and restrictions must preserve a minimum daytime sample,
# otherwise the bot starts optimizing on too little live paper flow.
SCALPER_REGIME_FILTER_MODE=trend_side_aware
SCALPER_INTRADAY_TICKER_LOSS_LIMIT_RUB=250
SCALPER_INTRADAY_TICKER_MAX_CONSECUTIVE_LOSSES=4
# Do not freeze a ticker after a pair of time-stop exits: keep paper collecting
# live flow and let the broader ticker loss guard carry the safety burden.
SCALPER_INTRADAY_TICKER_MAX_CONSECUTIVE_TIME_STOP_LOSSES=0
SCALPER_PAPER_TICKER_GUARD_COOLDOWN_SECONDS=900
SCALPER_PAPER_CONTINUE_AFTER_DAILY_LOSS_LIMIT=1
SCALPER_INTRADAY_SESSION_MAX_GUARDED_TICKERS=0
SCALPER_COLLECTION_GUARD_MIN_TRADES=3
SCALPER_COLLECTION_GUARD_MIN_TRADE_SHARE_PCT=35
SCALPER_COLLECTION_GUARD_MIN_SIGNAL_SHARE_PCT=35
